# Public host used by Traefik router rule
WATCHTUBE_HOST=watchtube.example.com

# Traefik integration
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# Prisma / MariaDB (example)
# mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL=mysql://watchtube:change-me@db:3306/watchtube

# Required in production (use a long random string)
JWT_SECRET=change-me-long-random-secret

# Optional (8..15)
BCRYPT_COST=12
